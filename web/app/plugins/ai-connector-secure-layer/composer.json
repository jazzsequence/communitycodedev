{
    "name": "jazzsequence/ai-connector-secure-layer",
    "type": "wordpress-plugin",
    "description": "Browser-key-protected LLM API key storage for WordPress AI Connectors. Stores only AES-256-GCM ciphertext server-side; the encryption key lives in sessionStorage and is sent per-request over HTTPS.",
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Reynolds",
            "email": "chris.reynolds@pantheon.io",
            "homepage": "https://github.com/jazzsequence"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "pantheon-systems/wpunit-helpers": "*",
        "pantheon-systems/pantheon-wp-coding-standards": "*",
        "roave/security-advisories": "dev-latest"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pantheon-systems/wpunit-helpers": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AICSL\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit -c phpunit-integration.xml",
        "lint": "@lint:phpcs",
        "lint:phpcs": "phpcs",
        "lint:phpcbf": "phpcbf"
    }
}
