{
    "name": "jazzsequence/ai-connector-secure-layer",
    "type": "wordpress-plugin",
    "description": "Keeps LLM API keys out of the WordPress database. Fetches keys from Pantheon Secrets or environment variables on-demand at the moment an LLM request fires — never stored in wp_options, never pre-loaded as a PHP constant.",
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Reynolds",
            "email": "chris.reynolds@pantheon.io",
            "homepage": "https://github.com/jazzsequence"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "pantheon-systems/pantheon-wp-coding-standards": "*",
        "pantheon-systems/wpunit-helpers": "*",
        "phpunit/phpunit": "^9.0",
        "roave/security-advisories": "dev-latest",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pantheon-systems/wpunit-helpers": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AICSL\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:phpunit": "@phpunit",
        "test:integration": "phpunit -c phpunit-integration.xml --do-not-cache-result",
        "test": [
            "@test:phpunit",
            "@test:integration"
        ],
        "test:install": "bin/install-local-tests.sh --skip-db=true",
		"test:install:withdb": "bin/install-local-tests.sh",
        "phpunit": "phpunit --do-not-cache-result",
        "lint": "@lint:phpcs",
        "lint:phpcs": "phpcs",
        "lint:phpcbf": "phpcbf"
    }
}
