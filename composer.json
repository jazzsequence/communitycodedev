{
    "name": "jazzsequence/communitycodedev",
    "type": "project",
    "license": "MIT",
    "description": "A podcast about the people behind the commits.",
    "homepage": "https://communitycode.dev",
    "authors": [
        {
            "name": "Pantheon Systems",
            "homepage": "https://pantheon.io"
        },
        {
            "name": "John Spellman",
            "email": "john.spellman@pantheon.io",
            "homepage": "https://github.com/jspellman814"
        },
        {
            "name": "Chris Reynolds",
            "email": "chris.reynolds@pantheon.io",
            "homepage": "https://github.com/jazzsequence"
        },
        {
            "name": "Scott Walkinshaw",
            "email": "scott.walkinshaw@gmail.com",
            "homepage": "https://github.com/swalkinshaw"
        },
        {
            "name": "Ben Word",
            "email": "ben@benword.com",
            "homepage": "https://github.com/retlehs"
        }
    ],
    "keywords": [
        "bedrock",
        "composer",
        "roots",
        "wordpress",
        "wp",
        "wp-config",
        "pantheon"
    ],
    "support": {
        "issues": "https://github.com/pantheon-systems/wordpress-composer-managed/issues",
        "docs": "https://pantheon.io/docs/guides/wordpress-composer"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": [
                "wpackagist-plugin/*",
                "wpackagist-theme/*"
            ]
        },
        {
            "type": "composer",
            "url": "https://repo.wp-packages.org",
            "only": [
                "wp-plugin/*",
                "wp-theme/*"
            ]
        },
        {
          "type": "composer",
          "url": "https://objectcache.pro/repo/"
        },
        {
            "type": "path",
            "url": "upstream-configuration"
        },
        {
          "type": "composer",
          "url": "https://packages.jazzsequence.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "10up/elasticpress": "^5.3",
        "composer/installers": "^2.2",
        "cweagans/composer-patches": "^1.7",
        "fairpm/fair-plugin": "*",
        "humanmade/two-factor": "*",
        "oscarotero/env": "^2.1",
        "pantheon-systems/pantheon-hud": "*",
        "pantheon-systems/pantheon-mu-plugin": "*",
        "pantheon-upstreams/upstream-configuration": "dev-main",
        "rhubarbgroup/object-cache-pro": "*",
        "roots/bedrock-autoloader": "*",
        "roots/bedrock-disallow-indexing": "*",
        "roots/wordpress": "*",
        "roots/wp-config": "*",
        "vlucas/phpdotenv": "^5.5",
        "wp-plugin/akismet": "*",
        "wp-plugin/altis-accelerate": "^3.5",
        "wp-plugin/autoblue": "*",
        "wp-plugin/block-accessibility-checks": "^2.2",
        "wp-plugin/imagify": "*",
        "wp-plugin/integromat-connector": "*",
        "wp-plugin/mailpoet": "*",
        "wp-plugin/ninja-forms": "*",
        "pantheon-systems/pantheon-advanced-page-cache": "*",
        "wp-plugin/powerpress": "*",
        "wp-plugin/progress-planner": "*",
        "wp-plugin/wp-mail-smtp": "*",
        "pantheon-systems/wp-native-php-sessions": "*",
        "wp-theme/twentytwentyfive": "*",
        "yoast/wordpress-seo": "*"
    },
    "require-dev": {
        "pantheon-systems/pantheon-wp-coding-standards": "*",
        "roave/security-advisories": "dev-latest",
        "assertwell/shellcheck": "^1.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "process-timeout": 0,
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3.14"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "web/app/mu-plugins/{$name}/": [
              "type:wordpress-muplugin",
              "fair/fair-plugin"
            ],
            "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
            "web/app/themes/{$name}/": ["type:wordpress-theme"]
        },
        "wordpress-install-dir": "web/wp",
        "composer-scaffold": {
            "locations": {
                "web-root": "./"
            }
        },
        "composer-exit-on-patch-failure": true,
        "enable-patching": true
    },
    "autoload": {
        "classmap": ["upstream-configuration/scripts/ComposerScripts.php"]
    },
    "scripts": {
        "post-install-cmd": "@maybe-create-symlinks",
        "pre-update-cmd": ["WordPressComposerManaged\\ComposerScripts::preUpdate"],
        "install-sage": ["bash ./private/scripts/helpers.sh install_sage"],
        "maybe-create-symlinks": ["bash ./private/scripts/helpers.sh maybe_create_symlinks"],
        "lint": [
            "@lint:php",
            "@lint:phpcs",
            "@lint:bash"
        ],
        "lint:php": [
            "find ./web/app/mu-plugins -name '*.php' -not -path '*/pantheon-mu-plugin/*' -not -path '*/bedrock-disallow-indexing/*' -not -name 'bedrock-autoloader.php' -not -name 'filters.php' -print0 | xargs -0 -n1 php -l"
        ],
        "lint:phpcs": ["vendor/bin/phpcs -s ."],
        "lint:phpcbf": ["vendor/bin/phpcbf ."],
        "lint:bash": ["shellcheck private/scripts/*.sh"],
        "test": [],
        "post-update-cmd": [
            "WordPressComposerManaged\\ComposerScripts::postUpdate",
            "@maybe-create-symlinks"
        ],
        "deploy": [
            "bash ./private/scripts/deploy.sh"
        ],
        "deploy:test": [
            "terminus env:deploy communitycodedev.test"
        ],
        "ep:sync": "terminus wp communitycodedev.live -- elasticpress sync --show-errors",
        "ep:setup": "terminus wp communitycodedev.live -- elasticpress sync --setup --show-errors --yes"
    },
    "suggest": {
        "pantheon-systems/upstream-management": "Composer plugin that provides commands for managing custom upstreams on Pantheon."
    }
}
